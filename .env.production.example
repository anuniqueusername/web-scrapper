# =============================================================================
# .env.production.example — Kijiji Competitor Scraper
#
# Copy this file to .env.production on the server and fill in real values:
#   cp .env.production.example .env.production
#   nano .env.production
#
# IMPORTANT: Never commit .env.production to git.
#            The .gitignore already excludes *.production files.
#
# On the server this file lives at:
#   /var/www/web-scraper/shared/.env.production
# And is symlinked into each release by deploy.sh.
# =============================================================================

# ---------------------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------------------

# Set to production — required for Next.js to serve the optimised build
NODE_ENV=production

# The public URL of your app (used by Next.js for canonical URLs, redirects)
# Include protocol and no trailing slash.
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# Internal port Next.js listens on (PM2 ecosystem.config.js must match)
PORT=3000

# ---------------------------------------------------------------------------
# Puppeteer / Chromium
# ---------------------------------------------------------------------------

# Path to the system Chromium binary installed by setup-droplet.sh
# Run: which chromium-browser   on the server to confirm the path
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Skip Puppeteer's bundled Chromium download during npm ci (use system Chrome)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# ---------------------------------------------------------------------------
# Notifications — Discord
# ---------------------------------------------------------------------------

# Discord incoming webhook URL for new listing alerts
# Create at: Server Settings -> Integrations -> Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Separate webhook for deployment status notifications (optional)
DISCORD_DEPLOY_WEBHOOK=https://discord.com/api/webhooks/YOUR_DEPLOY_WEBHOOK_ID/YOUR_DEPLOY_WEBHOOK_TOKEN

# ---------------------------------------------------------------------------
# Notifications — Slack
# ---------------------------------------------------------------------------

# Slack incoming webhook URL for new listing alerts
# Create at: https://api.slack.com/apps -> Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ---------------------------------------------------------------------------
# Scraper defaults
# (These are overridden at runtime by scraper-config.json via the dashboard)
# ---------------------------------------------------------------------------

# Default Kijiji search URL (used if scraper-config.json doesn't exist yet)
SCRAPER_DEFAULT_URL=https://www.kijiji.ca/b-canada/vending-machine/k0l0?view=list

# Default scrape interval in milliseconds (60000 = 1 minute)
SCRAPER_DEFAULT_INTERVAL=60000

# ---------------------------------------------------------------------------
# Security (optional hardening)
# ---------------------------------------------------------------------------

# If you add an authentication layer to the dashboard in the future,
# put a long random string here and use it to sign session tokens.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_HEX_STRING
