# Discord Webhook Configuration (Free - No email server needed!)
# How to get your Discord webhook URL:
# 1. Create a Discord server (if you don't have one)
# 2. Create a channel (e.g., #vending-machine-alerts)
# 3. Right-click channel → Edit Channel → Integrations → Webhooks
# 4. Create New Webhook → Copy Webhook URL
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Slack Webhook Configuration (Free - No email server needed!)
# How to get your Slack webhook URL:
# 1. Go to https://api.slack.com/apps
# 2. Create New App → From scratch
# 3. Enable Incoming Webhooks
# 4. Add New Webhook to Workspace
# 5. Copy the Webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_ID/YOUR_TOKEN
